datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  gstNumber   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  users             User[]
  products          Product[]
  categories        Category[]
  rawMaterials      RawMaterial[]
  warehouses        Warehouse[]
  inventoryItems    InventoryItem[]
  stockMovements    StockMovement[]
  productionOrders  ProductionOrder[]
  boms              BillOfMaterials[]
  machines          Machine[]
  employees         Employee[]
  customers         Customer[]
  suppliers         Supplier[]
  purchaseOrders    PurchaseOrder[]
  salesOrders       SalesOrder[]
  invoices          Invoice[]
  payments          Payment[]
  expenses          Expense[]
  auditLogs         AuditLog[]
  aiConversations   AIConversation[]
  notifications     Notification[]
  settings          Settings[]
  purchaseInvoices  PurchaseInvoice[]
  goodsReceipts     GoodsReceipt[]
  invoiceAIAliases  InvoiceAIAlias[]
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  email        String   @unique
  passwordHash String?                      // Nullable — Google-only users have no password
  googleId     String?  @unique             // Google OAuth "sub" identifier
  name         String
  role         String   @default("Viewer") // Owner, Admin, Manager, Accountant, Production, Warehouse, Sales, Viewer
  isActive     String   @default("true")   // Using string "true"/"false" or boolean
  twoFactorSecret String?
  isTwoFactorEnabled Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  company      Company  @relation(fields: [companyId], references: [id])
  auditLogs    AuditLog[]
  conversations AIConversation[]
}

model Category {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  products    Product[]
  rawMaterials RawMaterial[]
}

model Product {
  id          String   @id @default(uuid())
  companyId   String
  categoryId  String?
  sku         String
  name        String
  description String?
  price       Float    @default(0.0) // Selling price
  cost        Float    @default(0.0) // Production cost
  unit        String   @default("pcs") // pcs, kg, m, etc.
  type        String   @default("Finished") // Finished, SemiFinished
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company   @relation(fields: [companyId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
  boms        BillOfMaterials[]
  productionOrders ProductionOrder[]
  inventoryItems InventoryItem[]
  salesOrderItems SalesOrderItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  invoiceAIAliases InvoiceAIAlias[]
}

model RawMaterial {
  id          String   @id @default(uuid())
  companyId   String
  categoryId  String?
  sku         String
  name        String
  description String?
  cost        Float    @default(0.0) // Purchase cost
  unit        String   @default("kg") // kg, liter, pcs, etc.
  minStock    Float    @default(0.0) // Low stock trigger level
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company   @relation(fields: [companyId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
  bomItems    BOMItem[]
  inventoryItems InventoryItem[]
  purchaseOrderItems PurchaseOrderItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  invoiceAIAliases InvoiceAIAlias[]
}

model Warehouse {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  inventoryItems InventoryItem[]
  stockMovementsFrom StockMovement[] @relation("sourceWarehouse")
  stockMovementsTo StockMovement[] @relation("destWarehouse")
  goodsReceipts GoodsReceipt[]
}

model InventoryItem {
  id            String   @id @default(uuid())
  companyId     String
  warehouseId   String
  productId     String?
  rawMaterialId String?
  quantity      Float    @default(0.0)
  batchNumber   String?
  expiryDate    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // Relations
  company      Company      @relation(fields: [companyId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])
  rawMaterial  RawMaterial? @relation(fields: [rawMaterialId], references: [id])
}

model StockMovement {
  id                String   @id @default(uuid())
  companyId         String
  sourceWarehouseId String?
  destWarehouseId   String?
  productId         String?
  rawMaterialId     String?
  quantity          Float
  type              String   // Receive, Issue, Transfer, Adjustment, Consumption
  reference         String?  // PO Number, SO Number, Production Order ID, etc.
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  company         Company    @relation(fields: [companyId], references: [id])
  sourceWarehouse Warehouse? @relation("sourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destWarehouse   Warehouse? @relation("destWarehouse", fields: [destWarehouseId], references: [id])
}

model BillOfMaterials {
  id          String   @id @default(uuid())
  companyId   String
  productId   String
  name        String
  description String?
  version     String   @default("1.0")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  items       BOMItem[]
  productionOrders ProductionOrder[]
}

model BOMItem {
  id            String   @id @default(uuid())
  bomId         String
  rawMaterialId String
  quantity      Float    // Required quantity per unit of product
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // Relations
  bom          BillOfMaterials @relation(fields: [bomId], references: [id])
  rawMaterial  RawMaterial     @relation(fields: [rawMaterialId], references: [id])
}

model ProductionOrder {
  id          String   @id @default(uuid())
  companyId   String
  productId   String
  bomId       String
  machineId   String?
  quantity    Float
  status      String   @default("Pending") // Pending, InProgress, Completed, Cancelled
  cost        Float    @default(0.0) // Production cost calculated
  waste       Float    @default(0.0) // Material waste tracked
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  bom         BillOfMaterials @relation(fields: [bomId], references: [id])
  machine     Machine? @relation(fields: [machineId], references: [id])
}

model Machine {
  id              String   @id @default(uuid())
  companyId       String
  name            String
  code            String
  status          String   @default("Active") // Active, Maintenance, Offline
  runningHours    Float    @default(0.0)
  lastMaintenance DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  company         Company  @relation(fields: [companyId], references: [id])
  productionOrders ProductionOrder[]
  maintenanceLogs  MaintenanceLog[]
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  machineId   String
  description String
  cost        Float    @default(0.0)
  scheduledAt DateTime
  completedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  machine     Machine  @relation(fields: [machineId], references: [id])
}

model Employee {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  email        String?
  phone        String?
  department   String   // Production, Warehouse, Quality, Admin, Sales
  role         String?  // Worker, Supervisor, Manager
  salary       Float    @default(0.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  company      Company  @relation(fields: [companyId], references: [id])
  attendance   Attendance[]
}

model Attendance {
  id          String   @id @default(uuid())
  employeeId  String
  date        DateTime
  status      String   @default("Present") // Present, Absent, Leave, Late
  clockIn     DateTime?
  clockOut    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Customer {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  creditLimit Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  salesOrders SalesOrder[]
  invoices    Invoice[]
}

model Supplier {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  rating      Float    @default(5.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  purchaseOrders PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  companyId   String
  supplierId  String
  poNumber    String
  status      String   @default("Draft") // Draft, Ordered, Received, Cancelled
  totalAmount Float    @default(0.0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id            String   @id @default(uuid())
  purchaseOrderId String
  rawMaterialId String
  quantity      Float
  unitCost      Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // Relations
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  rawMaterial   RawMaterial   @relation(fields: [rawMaterialId], references: [id])
}

model SalesOrder {
  id          String   @id @default(uuid())
  companyId   String
  customerId  String
  soNumber    String
  status      String   @default("Draft") // Draft, Confirmed, Shipped, Cancelled
  totalAmount Float    @default(0.0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
  items       SalesOrderItem[]
  invoices    Invoice[]
}

model SalesOrderItem {
  id           String   @id @default(uuid())
  salesOrderId String
  productId    String
  quantity     Float
  unitPrice    Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
}

model Invoice {
  id           String   @id @default(uuid())
  companyId    String
  customerId   String
  salesOrderId String?
  invoiceNumber String
  status       String   @default("Unpaid") // Unpaid, Paid, Overdue, Cancelled
  dueDate      DateTime
  subTotal     Float    @default(0.0)
  taxAmount    Float    @default(0.0) // e.g., GST
  totalAmount  Float    @default(0.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  company      Company     @relation(fields: [companyId], references: [id])
  customer     Customer    @relation(fields: [customerId], references: [id])
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
  payments     Payment[]
}

model Payment {
  id          String   @id @default(uuid())
  companyId   String
  invoiceId   String
  amount      Float
  method      String   // Cash, Bank, Card, UPI
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  companyId   String
  category    String   // Rent, Utilities, Salaries, Raw Materials, Maintenance, Other
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String
  userId      String?
  action      String   // Create, Update, Delete, Login, etc.
  entity      String   // Table name
  entityId    String?
  details     String?  // JSON serialized edits
  ipAddress   String?
  createdAt   DateTime @default(now())

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

model AIConversation {
  id          String   @id @default(uuid())
  companyId   String
  userId      String
  message     String
  response    String
  createdAt   DateTime @default(now())

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  message     String
  type        String   // Info, Warning, Alert
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])
}

model Settings {
  id          String   @id @default(uuid())
  companyId   String
  key         String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
}

// ==========================================
// DOCUMENT INTELLIGENCE PLATFORM
// ==========================================

model PurchaseInvoice {
  id              String    @id @default(uuid())
  companyId       String
  supplierId      String?
  supplierName    String    // raw from OCR if supplier not found
  supplierGst     String?
  invoiceNumber   String
  invoiceDate     DateTime?
  poNumber        String?   // linked purchase order number
  subtotal        Float     @default(0)
  cgst            Float     @default(0)
  sgst            Float     @default(0)
  igst            Float     @default(0)
  freight         Float     @default(0)
  packingCharges  Float     @default(0)
  roundOff        Float     @default(0)
  totalAmount     Float     @default(0)
  status          String    @default("Posted") // Posted, Cancelled
  rawOcrJson      String?   // full Gemini extraction stored for audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company         Company          @relation(fields: [companyId], references: [id])
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  items           PurchaseInvoiceItem[]
  goodsReceipt    GoodsReceipt?
}

model PurchaseInvoiceItem {
  id                  String   @id @default(uuid())
  purchaseInvoiceId   String
  rawMaterialId       String?
  productId           String?
  supplierProductName String   // original text from invoice
  description         String?
  hsn                 String?
  quantity            Float
  unit                String   @default("pcs")
  unitPrice           Float
  discount            Float    @default(0)
  cgst                Float    @default(0)
  sgst                Float    @default(0)
  igst                Float    @default(0)
  lineTotal           Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
  rawMaterial     RawMaterial?    @relation(fields: [rawMaterialId], references: [id])
  product         Product?        @relation(fields: [productId], references: [id])
}

model GoodsReceipt {
  id                String    @id @default(uuid())
  companyId         String
  purchaseInvoiceId String    @unique
  warehouseId       String
  receivedAt        DateTime  @default(now())
  notes             String?
  createdAt         DateTime  @default(now())

  company         Company         @relation(fields: [companyId], references: [id])
  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])
}

model InvoiceAIAlias {
  id                  String   @id @default(uuid())
  companyId           String
  supplierProductName String   // text as it appeared on the invoice
  internalName        String   // the mapped internal product name
  rawMaterialId       String?
  productId           String?
  confidence          Float    @default(1.0)
  usageCount          Int      @default(1)
  lastUsedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  rawMaterial RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  product     Product?     @relation(fields: [productId], references: [id])

  @@unique([companyId, supplierProductName])
}
